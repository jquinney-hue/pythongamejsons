    {
      "html": "<span style=\"font-size:0.9rem\">Print 'You have enough!' if <span class=\"green-keyword\">coins</span> is greater than or equal to <span class=\"green-keyword\">5</span>.</span>",
      "keywords": ["if", "coins", ">="],
